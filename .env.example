# ─── Branding (build-time, Vite) ──────────────────────────────────────────
# Todas as variáveis VITE_BRAND_* são injetadas em tempo de build.
# O cookbook edita estas variáveis a partir das respostas do usuário.
VITE_BRAND_NAME="Whitelabel Learn"
VITE_BRAND_SHORT="Curso"
VITE_BRAND_TAGLINE="Aprenda passo a passo"
VITE_BRAND_STORAGE_PREFIX="wl-course"
VITE_BRAND_CERT_WATERMARK="W H I T E L A B E L   L E A R N"

# ─── URLs públicas ────────────────────────────────────────────────────────
VITE_API_URL=/api
VITE_APP_URL=https://exemplo.com
VITE_VALIDATE_URL=https://exemplo.com/validate

# ─── Backend ──────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=troque-em-producao-gere-com-openssl-rand-hex-32

# CORS: domínios permitidos, separados por vírgula. Nunca use "*" em produção.
CORS_ORIGIN=https://exemplo.com

PORT=3001

# ─── Banco (docker-compose) ───────────────────────────────────────────────
POSTGRES_DB=wl_course
POSTGRES_USER=learner
POSTGRES_PASSWORD=troque-em-producao

# Alternativa: URL completa (sobrepõe as três acima quando usada em dev local)
DATABASE_URL=postgresql+asyncpg://learner:troque-em-producao@localhost:5432/wl_course
