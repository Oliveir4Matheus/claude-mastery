# Backend
# Use strong, randomly-generated database credentials
DATABASE_URL=postgresql://user:password@localhost:5432/claude_mastery

# JWT_SECRET must be at least 32 characters, randomly generated using openssl rand -hex 16
# CRITICAL: Change this in production! Use: openssl rand -hex 32
JWT_SECRET=your-randomly-generated-32-character-secret-key-here-change-in-production

PORT=3001

# CORS_ORIGIN must be set to your exact production domain(s)
# Never use "*" in production. Format: https://domain1.com,https://domain2.com
CORS_ORIGIN=https://claude-mastery.app

# Frontend
VITE_API_URL=/api
VITE_APP_URL=https://claude-mastery.app
VITE_VALIDATE_URL=https://claude-mastery.app/validate
