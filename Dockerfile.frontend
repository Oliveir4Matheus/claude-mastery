FROM node:22-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ARG VITE_API_URL=/api
ARG VITE_APP_URL=
ARG VITE_VALIDATE_URL=
ARG VITE_BRAND_NAME="Whitelabel Learn"
ARG VITE_BRAND_SHORT="Curso"
ARG VITE_BRAND_TAGLINE="Aprenda passo a passo"
ARG VITE_BRAND_STORAGE_PREFIX="wl-course"
ARG VITE_BRAND_CERT_WATERMARK="W H I T E L A B E L   L E A R N"

ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_APP_URL=${VITE_APP_URL}
ENV VITE_VALIDATE_URL=${VITE_VALIDATE_URL}
ENV VITE_BRAND_NAME=${VITE_BRAND_NAME}
ENV VITE_BRAND_SHORT=${VITE_BRAND_SHORT}
ENV VITE_BRAND_TAGLINE=${VITE_BRAND_TAGLINE}
ENV VITE_BRAND_STORAGE_PREFIX=${VITE_BRAND_STORAGE_PREFIX}
ENV VITE_BRAND_CERT_WATERMARK=${VITE_BRAND_CERT_WATERMARK}

RUN npm run build

FROM nginx:alpine

RUN apk add --no-cache curl

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
